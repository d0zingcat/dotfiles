# === 敏感数据排除 ===
# SSH 密钥和配置
.ssh/
known_hosts
authorized_keys
id_rsa*
id_ed25519*
*.pem

# 1Password
.1password/

# Kubernetes
.kube/
kubeconfig*
*.kubeconfig

# 环境变量和 secrets
*.secret
*.key
credentials.json
secrets.txt

# 缓存目录
__pycache__/
.pytest_cache/
.mypy_cache/
.node_cache/
.cache/
tmp/
temp/

# IDE
.idea/
.vscode/workspace*
*.swp
*.swo
*~

# 语言版本文件
.python-version
.node-version
.rust-version
.tool-versions

# 构建产物
dist/
build/
target/
*.o
*.a
*.so
*.dylib

# Mac 特有
.Trash/
.VolumeIcon.icns
.apdisk

# 日志
*.log
npm-debug.log*
yarn-error.log
pnpm-debug.log*

# === 备份文件排除 ===
