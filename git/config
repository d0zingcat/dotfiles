[init]
  defaultBranch = main

[user]
  name = YOUR_NAME
  signingkey = YOUR_SSH_SIGNING_KEY
  email = YOUR_EMAIL

[commit]
  gpgsign = true

[gpg]
  format = ssh

[gpg "ssh"]
  program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"

[url "https://"]
    insteadOf = git://

[core]
    editor = nvim
	excludesfile = ~/.config/git/.gitignore

[pager]
    difftool = true

